# ============================================
# Ameizin - Environment Variables Template
# ============================================
# Copy file này thành .env.local
# KHÔNG commit .env.local lên repo

# --- App (public, nhúng vào JS bundle) ---
NEXT_PUBLIC_APP_NAME=Ameizin
NEXT_PUBLIC_BASE_PATH=

# --- Feature Flags ---
# true = dùng mock data, false = đọc từ static JSON (public/data/)
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# --- Crawl Script (server-side only, KHÔNG lộ ra browser) ---
# Optional: vnstock API key cho rate limit cao hơn (60 req/min thay vì 20)
# Đăng ký miễn phí tại vnstocks.com/login
VNSTOCK_API_KEY=

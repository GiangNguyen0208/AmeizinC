# ============================================
# Ameizin - Environment Variables Template
# ============================================

# --- App (public, nhúng vào JS bundle) ---
NEXT_PUBLIC_APP_NAME=Ameizin
NEXT_PUBLIC_BASE_PATH=

# --- Backend API ---
# Local dev: http://localhost:3001/api
# Production: https://ameizin-c-be.vercel.app/api
NEXT_PUBLIC_API_URL=https://ameizin-c-be.vercel.app/api

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# --- Crawl Script (server-side only, KHÔNG lộ ra browser) ---
VNSTOCK_API_KEY=

# ============================================
# Ameizin - Environment Variables Template
# ============================================

# --- App (public, nhúng vào JS bundle) ---
NEXT_PUBLIC_APP_NAME=Ameizin
NEXT_PUBLIC_BASE_PATH=

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Google OAuth (optional) ---
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_MOCK_DATA=true

# --- Crawl Script (server-side only, KHÔNG lộ ra browser) ---
VNSTOCK_API_KEY=
